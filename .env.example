NOVEL_INTERNAL_API_KEY=replace-with-a-long-random-server-to-server-secret
# D-05 author application rejection cooldown. ISO-8601 duration; P7D is seven days.
NOVEL_AUTHOR_APPLICATION_REJECTION_COOLDOWN=P7D
# Email registration is SMTP-backed and fail-closed. Do not put these values in NEXT_PUBLIC_*.
# QQ Mail example: enable SMTP in QQ Mail, set NOVEL_SMTP_HOST=smtp.qq.com and use the separate
# QQ SMTP authorization code below, never the QQ account password. Leave every required value
# blank only when email registration is intentionally unavailable (the browser receives 503).
NOVEL_EMAIL_VERIFICATION_ENABLED=true
NOVEL_EMAIL_VERIFICATION_FROM=
NOVEL_EMAIL_VERIFICATION_HASH_SECRET=replace-with-a-separate-long-random-hmac-secret
# Optional but required before a station administrator can persist SMTP settings in the
# operations console. Generate a distinct base64url-encoded 32-byte key; never reuse SMTP or HMAC secrets.
NOVEL_EMAIL_SETTINGS_ENCRYPTION_KEY=
NOVEL_EMAIL_VERIFICATION_CODE_TTL=PT10M
NOVEL_EMAIL_VERIFICATION_RESEND_COOLDOWN=PT60S
NOVEL_EMAIL_VERIFICATION_MAX_REQUESTS_PER_WINDOW=5
NOVEL_EMAIL_VERIFICATION_REQUEST_WINDOW=PT1H
NOVEL_EMAIL_VERIFICATION_MAX_VERIFICATION_ATTEMPTS=5
NOVEL_SMTP_HOST=
NOVEL_SMTP_PORT=465
NOVEL_SMTP_USERNAME=
NOVEL_SMTP_PASSWORD=
NOVEL_SMTP_AUTH=true
NOVEL_SMTP_SSL_ENABLE=true
NOVEL_SMTP_CONNECTION_TIMEOUT_MILLIS=5000
NOVEL_SMTP_TIMEOUT_MILLIS=10000
NOVEL_SMTP_WRITE_TIMEOUT_MILLIS=10000
MYSQL_PASSWORD=replace-with-a-long-random-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-long-random-root-password
# MinIO is private to Compose. The root credential is used only by the one-shot initializer;
# backend receives the separate writer identity below, and neither value belongs in NEXT_PUBLIC_*.
MINIO_ROOT_USER=replace-with-a-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-a-long-minio-root-password
MINIO_COVER_ACCESS_KEY=replace-with-a-cover-writer-access-key
MINIO_COVER_SECRET_KEY=replace-with-a-long-cover-writer-secret
# Leave disabled until MinIO/root/writer values above have been provisioned. Nginx alone exposes
# immutable objects through /media/; do not publish MinIO's 9000 or 9001 ports.
NOVEL_COVER_STORAGE_ENABLED=false
NOVEL_COVER_MAX_BYTES=5242880
NOVEL_COVER_MAX_WIDTH=4096
NOVEL_COVER_MAX_HEIGHT=4096
# Compose only publishes this Nginx listener. Keep backend and web service ports private.
# Production browser traffic must reach this endpoint through a real HTTPS terminator.
HTTP_PORT=80
# Required by the production BFF origin/CSRF gate. Use the HTTPS browser origin, without a path.
NOVEL_PUBLIC_ORIGIN=https://novel.example.com
# The default Compose value targets the private Redis service. Override only for managed Redis;
# never expose this value through NEXT_PUBLIC_ variables or browser configuration.
NOVEL_SESSION_REDIS_URL=redis://redis:6379/0
NOVEL_SESSION_REDIS_PREFIX=novel:bff:session:
NOVEL_SESSION_TTL_SECONDS=28800
# Authentication mutations are Redis-rate-limited independently from browser sessions. In a
# production-like runtime this guard cannot be disabled; Redis trouble fails authentication closed.
# Leave NOVEL_AUTH_RATE_LIMIT_REDIS_URL blank to use NOVEL_SESSION_REDIS_URL.
NOVEL_AUTH_RATE_LIMIT_ENABLED=true
NOVEL_AUTH_RATE_LIMIT_REDIS_URL=
NOVEL_AUTH_RATE_LIMIT_REDIS_PREFIX=novel:bff:auth-rate-limit:
NOVEL_AUTH_RATE_LIMIT_LOGIN_LIMIT=10
NOVEL_AUTH_RATE_LIMIT_REGISTER_LIMIT=5
NOVEL_AUTH_RATE_LIMIT_WINDOW_SECONDS=900
# Enable only when the ingress overwrites client supplied X-Forwarded-For values before Next.js.
NOVEL_AUTH_RATE_LIMIT_TRUSTED_PROXY_HEADERS=false
# Optional production bootstrap administrator. Set all three values with a unique, long password;
# leave all blank to disable account creation. Never commit real credentials.
NOVEL_BOOTSTRAP_ADMIN_USERNAME=
NOVEL_BOOTSTRAP_ADMIN_DISPLAY_NAME=
NOVEL_BOOTSTRAP_ADMIN_PASSWORD=
# Qwen moderation is backend-only and disabled by default. Never commit a real key.
NOVEL_RUNTIME_MODE=PRODUCTION
NOVEL_AUDIT_DEVELOPMENT_SIMULATION_ENABLED=false
QWEN_AUDIT_ENABLED=false
QWEN_AUDIT_BASE_URL=
QWEN_AUDIT_MODEL=
QWEN_AUDIT_TIMEOUT=PT20S
QWEN_AUDIT_MAX_RETRIES=0
QWEN_AUDIT_MAX_REQUESTS_PER_MINUTE=60
DASHSCOPE_API_KEY=
