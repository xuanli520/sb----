{
  "name": "yuejie-novel-platform-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "NEXT_TEST_WASM=1 next dev --webpack",
    "build": "NEXT_TEST_WASM=1 next build --webpack",
    "start": "next start",
    "start:standalone": "node server.js",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docker:build": "docker build -t yuejie-novel-web:latest .",
    "docker:run": ": \"${API_PROXY_TARGET:?API_PROXY_TARGET is required}\" && : \"${NOVEL_INTERNAL_API_KEY:?NOVEL_INTERNAL_API_KEY is required}\" && : \"${NOVEL_SESSION_REDIS_URL:?NOVEL_SESSION_REDIS_URL is required}\" && : \"${NOVEL_PUBLIC_ORIGIN:?NOVEL_PUBLIC_ORIGIN is required}\" && docker run -d -p 3000:3000 --name yuejie-novel-web -e API_PROXY_TARGET -e NOVEL_INTERNAL_API_KEY -e NOVEL_SESSION_REDIS_URL -e NOVEL_SESSION_REDIS_PREFIX -e NOVEL_SESSION_TTL_SECONDS -e NOVEL_AUTH_RATE_LIMIT_ENABLED -e NOVEL_AUTH_RATE_LIMIT_REDIS_URL -e NOVEL_AUTH_RATE_LIMIT_REDIS_PREFIX -e NOVEL_AUTH_RATE_LIMIT_LOGIN_LIMIT -e NOVEL_AUTH_RATE_LIMIT_REGISTER_LIMIT -e NOVEL_AUTH_RATE_LIMIT_WINDOW_SECONDS -e NOVEL_AUTH_RATE_LIMIT_TRUSTED_PROXY_HEADERS -e NOVEL_PUBLIC_ORIGIN yuejie-novel-web:latest",
    "docker:stop": "docker stop yuejie-novel-web && docker rm yuejie-novel-web",
    "docker:logs": "docker logs -f yuejie-novel-web",
    "prepare": "husky",
    "precommit:check": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.2",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.2",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "embla-carousel-react": "8.6.0",
    "gsap": "^3.15.0",
    "input-otp": "1.4.2",
    "lucide-react": "0.487.0",
    "next": "^16.1.4",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-day-picker": "8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "7.55.0",
    "react-resizable-panels": "2.1.7",
    "recharts": "2.15.2",
    "redis": "^6.1.0",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "three": "^0.182.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.10",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "msw": "^2.12.9",
    "tailwindcss": "4.1.12",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
