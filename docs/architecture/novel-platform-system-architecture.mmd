%% 阅界小说平台系统架构图
%% 实线：同步请求；虚线：存储、对象读写或可选外部依赖
flowchart TB
    classDef actor fill:#EAF3FF,stroke:#2563EB,stroke-width:1.5px,color:#111827
    classDef edge fill:#EAFBF2,stroke:#15803D,stroke-width:1.5px,color:#111827
    classDef frontend fill:#FFF7E6,stroke:#D97706,stroke-width:1.5px,color:#111827
    classDef backend fill:#F3E8FF,stroke:#7E22CE,stroke-width:1.5px,color:#111827
    classDef data fill:#FFF1F2,stroke:#BE123C,stroke-width:1.5px,color:#111827
    classDef external fill:#F1F5F9,stroke:#475569,stroke-width:1.5px,color:#111827
    classDef repo fill:#F8FAFC,stroke:#64748B,stroke-width:1.5px,color:#111827

    U["读者 / 作者 / 运营人员<br/>Browser"]:::actor

    subgraph PUBLIC["对外访问层"]
      direction LR
      C["Caddy<br/>TLS 终止"]:::edge
      N["Nginx<br/>单一 HTTP 入口<br/>/media 只读代理"]:::edge
    end

    subgraph APP["应用私网 Docker Network"]
      direction TB
      W["Next.js Web<br/>App Router + TypeScript + Tailwind<br/>读者端 / 作者端 / 运营端"]:::frontend
      BFF["Next.js BFF<br/>/api/novel/{public|account|author|admin}<br/>Origin + CSRF 校验、路径白名单<br/>注入内部密钥与后端会话"]:::frontend

      subgraph API["Spring Boot 4 / Java 21 模块化单体"]
        direction TB
        REST["REST API 层<br/>Controller + UserResolver<br/>输入、角色、归属、状态机校验"]:::backend
        AUTH["身份与会话<br/>AuthService / AccountProfileService<br/>账户、角色、后端登录会话、审计"]:::backend
        CONTENT["目录与创作<br/>Catalog / Book / Chapter 服务<br/>作品、卷章、草稿、排期、发布"]:::backend
        READER["阅读与互动<br/>Reader / Interaction 服务<br/>书架、进度、书签、评论、段评、投票"]:::backend
        TRADE["权益与账本<br/>Wallet / Redemption 服务<br/>会员、代币、购买、打赏、幂等"]:::backend
        OPS["内容运营与审核<br/>Moderation / Editorial / Media 服务<br/>敏感词、审核、推荐、热搜、封面"]:::backend
        METRICS["指标与定时任务<br/>Analytics / Publication Jobs<br/>作者指标、留存、定时发布"]:::backend
        PERSIST["JDBC + MyBatis-Plus Repository<br/>Flyway Schema Migration"]:::backend
      end
    end

    subgraph DATA["私有数据与对象存储"]
      direction LR
      R["Redis 7.4<br/>BFF 不透明会话映射<br/>认证限流"]:::data
      M["MySQL 8.4<br/>业务数据、账本、审计<br/>阅读活动与指标源"]:::data
      O["MinIO / S3<br/>封面、轮播图对象<br/>仅 /media 匿名 GET"]:::data
    end

    subgraph EXTERNAL["后端专属可选依赖"]
      direction LR
      Q["Qwen 兼容模型接口<br/>全书内容审核<br/>异常转人工复核"]:::external
      S["SMTP 服务商<br/>注册邮箱验证码"]:::external
    end

    subgraph REPO["项目文件结构参考（非运行时服务）"]
      direction LR
      WEB_CODE["apps/web/<br/>src/app：页面与 BFF 路由<br/>src/features/novel/api.ts：接口客户端<br/>src/lib/novel：BFF 会话与安全"]:::repo
      BACKEND_CODE["apps/backend/<br/>api：REST Controller<br/>service：领域服务与定时任务<br/>mapper：持久化映射；domain：模型<br/>resources/db/migration：Flyway SQL"]:::repo
      INFRA_CODE["infra/<br/>nginx/default.conf：单入口与 /media<br/>caddy/Caddyfile.example：TLS 外层代理"]:::repo
      OPS_CODE["compose.yaml + Dockerfile<br/>容器编排与镜像构建<br/>scripts/：备份、恢复、部署校验"]:::repo
      DOCS_CODE["docs/<br/>architecture/：本图与渲染配置<br/>openapi/：版本化 REST 契约<br/>06-deployment-and-recovery.md：部署说明"]:::repo
    end

    U -->|HTTPS| C
    C -->|loopback HTTP| N
    N -->|页面与 BFF 请求| W
    W -->|同源请求| BFF
    BFF -->|公开或受保护 REST API<br/>X-Novel-Internal-Key + 后端会话| REST
    BFF -.->|会话映射 / 认证限流| R
    N -.->|仅生成的 PNG/JPEG 的 GET| O

    REST --> AUTH
    REST --> CONTENT
    REST --> READER
    REST --> TRADE
    REST --> OPS
    REST --> METRICS
    AUTH --> PERSIST
    CONTENT --> PERSIST
    READER --> PERSIST
    TRADE --> PERSIST
    OPS --> PERSIST
    METRICS --> PERSIST
    PERSIST -.->|事务读写| M
    OPS -.->|封面与轮播图读写| O
    OPS -.->|内容审核，后端调用| Q
    AUTH -.->|发送验证码| S
    BFF -.->|代码实现| WEB_CODE
    PERSIST -.->|代码实现| BACKEND_CODE
    N -.->|配置实现| INFRA_CODE
    N -.->|部署编排| OPS_CODE
    REST -.->|接口契约| DOCS_CODE

    class PUBLIC,APP,API,DATA,EXTERNAL,REPO group
    style PUBLIC fill:#F8FAFC,stroke:#94A3B8,stroke-width:1px
    style APP fill:#FFFBEB,stroke:#F59E0B,stroke-width:1px
    style API fill:#FAF5FF,stroke:#A855F7,stroke-width:1px
    style DATA fill:#FFF7F7,stroke:#FB7185,stroke-width:1px
    style EXTERNAL fill:#F8FAFC,stroke:#94A3B8,stroke-width:1px,stroke-dasharray: 5 5
    style REPO fill:#F8FAFC,stroke:#64748B,stroke-width:1px,stroke-dasharray: 5 5
